{
  "name": "ui-lib",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "homepage": "https://ui-lib.quebi.de",
  "scripts": {
    "predev": "bun run generate:api",
    "dev": "react-router dev",
    "generate:api": "bun run scripts/generate-api.ts",
    "generate:og": "bun run scripts/generate-og.ts",
    "build": "bun run generate:api && bun run generate:og && react-router build",
    "start": "react-router-serve ./build/server/index.js",
    "preview": "vite preview",
    "typecheck": "bun run generate:api && react-router typegen && tsc -b"
  },
  "packageManager": "bun@1.3.14",
  "dependencies": {
    "@conform-to/react": "^1.19.4",
    "@conform-to/zod": "^1.19.4",
    "@internationalized/date": "^3.12.2",
    "clsx": "^2.1.1",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.460.0",
    "motion": "^12.42.2",
    "overlayscrollbars": "^2.16.0",
    "overlayscrollbars-react": "^0.5.6",
    "react": "^19.0.0",
    "react-aria-components": "^1.19.0",
    "react-dom": "^19.0.0",
    "react-router": "^8",
    "react-stately": "^3.48.0",
    "recharts": "^3.9.1",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@react-router/dev": "^8.1.0",
    "@react-router/fs-routes": "^8.1.0",
    "@react-router/node": "^8.1.0",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^26.0.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "satori": "^0.26.0",
    "shiki": "^4.3.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
